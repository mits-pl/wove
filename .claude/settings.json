{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wsh setrtinfo claude:state=idle 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wsh setrtinfo claude:state=working 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
